# ─── Lift Watch · environment ────────────────────────────────────────────────
# Copy this file to `.env` and fill in a Postgres connection string.
# Works with any Postgres provider that has a free tier, e.g.:
#   • Neon              https://neon.tech          (recommended, matches Vercel Postgres)
#   • Vercel Postgres   https://vercel.com/storage/postgres
#   • Supabase          https://supabase.com
#
# DATABASE_URL — used by the app at runtime (a POOLED connection is ideal on
# serverless/Vercel; on Neon this is the "-pooler" host).
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# DIRECT_URL — used only by `prisma migrate`. Must be a DIRECT (non-pooled)
# connection. If your provider doesn't distinguish, set it to the same value
# as DATABASE_URL and drop any "-pooler" from the host.
DIRECT_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Max size (in kilobytes) a report image is compressed down to before storing.
# Client reads NEXT_PUBLIC_ for the compressor; keep them in sync.
NEXT_PUBLIC_MAX_IMAGE_KB="20"

# Reports must use a freshly-taken photo: reject any image whose capture time
# (EXIF, or the file's timestamp) is older than this many minutes. Defaults to 5.
NEXT_PUBLIC_MAX_PHOTO_AGE_MIN="5"

# ─── Report rate limiting (Upstash Redis) ────────────────────────────────────
# Caps how many reports one device can file per IST day (all kinds combined).
# Create a free Redis DB at https://console.upstash.com and paste the REST
# credentials below. If these are left unset, rate limiting is simply disabled
# (handy for local dev).
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Max reports per device per day. Defaults to 5 if unset.
RATELIMIT_REPORTS_PER_DAY="5"

# ─── Admin ───────────────────────────────────────────────────────────────────
# Password for the admin panel (tap the red dot in the top bar → /admin) which
# can delete reports. If left blank, admin access is disabled entirely.
ADMIN_PASSWORD=""
